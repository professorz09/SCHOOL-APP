{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": ["ES2022"],
    "jsx": "preserve",
    "types": ["node"],
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true
  },
  "include": ["./**/*.ts", "../vite-plugins/**/*.ts"],
  "exclude": ["node_modules", "../node_modules"]
}
