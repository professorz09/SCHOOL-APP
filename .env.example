# ─────────────────────────────────────────────────────────────────────────────
#  EduGrow — environment variables
#
#  Copy this file to `.env.local` for local dev, OR paste each value into
#  Vercel → Settings → Environment Variables for production.
#  Never commit `.env.local` — `.gitignore` already excludes it.
# ─────────────────────────────────────────────────────────────────────────────


# ─── FRONTEND (Vite — bundled into the browser build) ───────────────────────
# These two are PUBLIC. They get baked into the JS shipped to the browser.
# Safe to expose because they're protected by Supabase RLS policies.

VITE_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
VITE_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR-ANON-KEY"


# ─── SERVER (Node/Vercel functions — never sent to the browser) ─────────────
# Service-role key has FULL DB access — keep it secret. Only set this on the
# server (Vercel "Environment Variables" panel), never in frontend code.

SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR-ANON-KEY"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR-SERVICE-ROLE-KEY"


# ─── OPTIONAL: direct DB connection (scripts only, not runtime) ─────────────
# Used by supabase CLI / one-off migration scripts. NOT needed for normal
# app operation — the app talks to Supabase over its REST API.

DATABASE_URL="postgresql://postgres.YOUR-REF:YOUR-DB-PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres"
SUPABASE_DB_PASSWORD="YOUR-DATABASE-PASSWORD"


# ─── OPTIONAL: AI features (question paper, OCR extract) ────────────────────
# Free tier key at https://aistudio.google.com/apikey. If empty, the AI
# panel in Tools auto-hides — rest of the app works fine.

GEMINI_API_KEY=""


# ─── OPTIONAL: CORS allowlist for /api/* ────────────────────────────────────
# Comma-separated origins. Leave empty in production (Vercel serves both
# frontend + API from same origin). Set only if running API on a separate
# domain.
# Example: CORS_ORIGINS="https://app.example.com,https://staging.example.com"

CORS_ORIGINS=""
