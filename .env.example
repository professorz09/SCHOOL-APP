# ─── Supabase (required) ─────────────────────────────────────────────────────
# These are read both by the frontend (Vite reads them at build/dev time) and
# by the migration / seed scripts.
SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
SUPABASE_ANON_KEY="YOUR-PUBLIC-ANON-KEY"

# ─── Service role + DB password (required only for db:* scripts) ────────────
# NEVER expose these in frontend code. Used only by scripts/* with admin access.
SUPABASE_SERVICE_ROLE_KEY="YOUR-SERVICE-ROLE-KEY"
SUPABASE_DB_PASSWORD="YOUR-DATABASE-PASSWORD"
# Optional cache so db:apply doesn't have to scan every Supavisor region.
# Find it the first time db:apply runs (it prints the working host).
SUPABASE_DB_HOST="aws-1-ap-northeast-1.pooler.supabase.com"

# ─── Gemini AI (optional) ────────────────────────────────────────────────────
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ─── Hosting URL (auto-injected by Replit / AI Studio) ──────────────────────
APP_URL="MY_APP_URL"
